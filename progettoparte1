RIGA 386:       const t = splitTags[i].trim();
RIGA 387:       if (t) tags.push(t);
RIGA 388:     }
RIGA 389:   }
RIGA 390:   const ingredienti = piattoRaw.ingredients || piattoRaw.ingredienti || [];
RIGA 391:   const measures = piattoRaw.measures || piattoRaw.misure || [];
RIGA 392:   const categoria = piattoRaw.strCategory || piattoRaw.categoria || 'Altro';
