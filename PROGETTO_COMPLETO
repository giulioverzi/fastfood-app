RIGA 966: // Calcola le statistiche dagli ordini
RIGA 967: function calcolaStatistiche(ordini) {
RIGA 968:   const totaleOrdini = ordini.length;
RIGA 969:   
RIGA 970:   let conteggioInSospeso = 0;
RIGA 971:   for (let i = 0; i < ordini.length; i++) {
RIGA 972:     if (ordini[i].stato !== 'consegnato' && ordini[i].stato !== 'annullato') {
RIGA 973:       conteggioInSospeso++;
RIGA 974:     }
RIGA 975:   }
RIGA 976:   const ordiniInSospeso = conteggioInSospeso;
RIGA 977:   
RIGA 978:   let conteggioCompletati = 0;
RIGA 979:   for (let i = 0; i < ordini.length; i++) {
RIGA 980:     if (ordini[i].stato === 'consegnato') {
RIGA 981:       conteggioCompletati++;
RIGA 982:     }
RIGA 983:   }
RIGA 984:   const ordiniCompletati = conteggioCompletati;
RIGA 985:   
RIGA 986:   let incassoTotale = 0;
RIGA 987:   for (let i = 0; i < ordini.length; i++) {
RIGA 988:     if (ordini[i].stato === 'consegnato') {
RIGA 989:       incassoTotale += Number(ordini[i].totaleCentesimi) || 0;
RIGA 990:     }
RIGA 991:   }
RIGA 992:   
RIGA 993:   const conteggiPiatti = {};
RIGA 994:   for (let i = 0; i < ordini.length; i++) {
RIGA 995:     const ordine = ordini[i];
RIGA 996:     if (!ordine.piatti || !Array.isArray(ordine.piatti)) continue;
RIGA 997:     
RIGA 998:     for (let j = 0; j < ordine.piatti.length; j++) {
RIGA 999:       const elemento = ordine.piatti[j];
RIGA 1000:       if (!elemento || !elemento.piatto) continue;
RIGA 1001:       
RIGA 1002:       const piattoId = elemento.piatto._id || elemento.piatto;
RIGA 1003:       const nomePiatto = elemento.piatto.nome || 'Piatto sconosciuto';
RIGA 1004:       const categoriaPiatto = elemento.piatto.categoria || '';
RIGA 1005:       const quantita = parseInt(elemento.quantita) || 0;
RIGA 1006:       
RIGA 1007:       if (!conteggiPiatti[piattoId]) {
RIGA 1008:         conteggiPiatti[piattoId] = {
RIGA 1009:           name: nomePiatto,
RIGA 1010:           category: categoriaPiatto,
RIGA 1011:           count: 0
RIGA 1012:         };
RIGA 1013:       }
RIGA 1014:       conteggiPiatti[piattoId].count += quantita;
RIGA 1015:     }
RIGA 1016:   }
RIGA 1017:   
RIGA 1018:   const chiavi = Object.keys(conteggiPiatti);
RIGA 1019:   let piattiPiuOrdinati = [];
RIGA 1020:   for (let i = 0; i < chiavi.length; i++) {
RIGA 1021:     const id = chiavi[i];
RIGA 1022:     piattiPiuOrdinati.push({ id: id, name: conteggiPiatti[id].name, category: conteggiPiatti[id].category, count: conteggiPiatti[id].count });
RIGA 1023:   }
RIGA 1024:   for (let i = 0; i < piattiPiuOrdinati.length - 1; i++) {
RIGA 1025:     for (let j = i + 1; j < piattiPiuOrdinati.length; j++) {
RIGA 1026:       if (piattiPiuOrdinati[j].count > piattiPiuOrdinati[i].count) {
RIGA 1027:         const temp = piattiPiuOrdinati[i];
RIGA 1028:         piattiPiuOrdinati[i] = piattiPiuOrdinati[j];
RIGA 1029:         piattiPiuOrdinati[j] = temp;
RIGA 1030:       }
RIGA 1031:     }
RIGA 1032:   }
RIGA 1033:   piattiPiuOrdinati = piattiPiuOrdinati.slice(0, 4);
RIGA 1034:   
RIGA 1035:   return {
RIGA 1036:     totalOrders: totaleOrdini,
RIGA 1037:     pendingOrders: ordiniInSospeso,
RIGA 1038:     completedOrders: ordiniCompletati,
RIGA 1039:     totalRevenue: incassoTotale,
RIGA 1040:     mostOrdered: piattiPiuOrdinati
RIGA 1041:   };
RIGA 1042: }
